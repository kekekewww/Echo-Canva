{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/scene-spec.schema.json",
  "title": "Spatial Audio SceneSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "revision",
    "units",
    "name",
    "room",
    "walls",
    "portals",
    "sources",
    "listener",
    "settings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    },
    "units": {
      "const": "m"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outerPolygon",
        "heightM",
        "floorMaterialId",
        "ceilingMaterialId"
      ],
      "properties": {
        "outerPolygon": {
          "type": "array",
          "minItems": 3,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/vec2"
          }
        },
        "heightM": {
          "type": "number",
          "minimum": 2,
          "maximum": 12
        },
        "floorMaterialId": {
          "$ref": "#/$defs/id"
        },
        "ceilingMaterialId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "walls": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "a",
          "b",
          "thicknessM",
          "materialId",
          "kind"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "a": {
            "$ref": "#/$defs/vec2"
          },
          "b": {
            "$ref": "#/$defs/vec2"
          },
          "thicknessM": {
            "type": "number",
            "minimum": 0.02,
            "maximum": 2
          },
          "materialId": {
            "$ref": "#/$defs/id"
          },
          "kind": {
            "enum": [
              "boundary",
              "partition"
            ]
          }
        }
      }
    },
    "portals": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "wallId",
          "center",
          "widthM",
          "heightM",
          "open",
          "lossDb"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "wallId": {
            "$ref": "#/$defs/id"
          },
          "center": {
            "$ref": "#/$defs/vec2"
          },
          "widthM": {
            "type": "number",
            "minimum": 0.4,
            "maximum": 8
          },
          "heightM": {
            "type": "number",
            "minimum": 1,
            "maximum": 6
          },
          "open": {
            "type": "boolean"
          },
          "lossDb": {
            "type": "number",
            "minimum": 0,
            "maximum": 24
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "clipId",
          "sourceType",
          "position",
          "gainDb",
          "loop"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "clipId": {
            "$ref": "#/$defs/id"
          },
          "sourceType": {
            "const": "point"
          },
          "position": {
            "$ref": "#/$defs/vec2"
          },
          "gainDb": {
            "type": "number",
            "minimum": -36,
            "maximum": 6
          },
          "loop": {
            "type": "boolean"
          }
        }
      }
    },
    "listener": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position",
        "headingDeg"
      ],
      "properties": {
        "position": {
          "$ref": "#/$defs/vec2"
        },
        "headingDeg": {
          "type": "number",
          "minimum": -360,
          "maximum": 360
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acousticUpdateHz",
        "maxEarlyReflections",
        "hrtfEnabled"
      ],
      "properties": {
        "acousticUpdateHz": {
          "type": "integer",
          "minimum": 5,
          "maximum": 20
        },
        "maxEarlyReflections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "hrtfEnabled": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,63}$"
    },
    "vec2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number",
          "minimum": -50,
          "maximum": 50
        },
        "y": {
          "type": "number",
          "minimum": -50,
          "maximum": 50
        }
      }
    }
  }
}