# Server-side only. The preset/manual application remains available without it.
# Both compiler and explanation routes use the required, hard-coded gpt-5.6 model.
OPENAI_API_KEY=
# Compilation uses this setting (low, medium, or high); explanation always uses low effort.
OPENAI_REASONING_EFFORT=medium
# Shared Responses API timeout for compilation and explanation, in milliseconds.
AI_REQUEST_TIMEOUT_MS=30000
