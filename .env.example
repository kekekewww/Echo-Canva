# Server-side only. The preset/manual application remains available without any key.
# Default official OpenAI configuration (both routes use gpt-5.6):
OPENAI_API_KEY=
# Optional live-test configuration. Do not enable both providers at once.
# When selected, both routes use the fixed OpenRouter model openai/gpt-5.6-luna.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Compilation uses this setting (low, medium, or high); explanation always uses low effort.
OPENAI_REASONING_EFFORT=medium
# Shared Responses API timeout for compilation and explanation, in milliseconds.
AI_REQUEST_TIMEOUT_MS=30000
